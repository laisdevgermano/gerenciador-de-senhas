// ============================================================
// ESQUEMA DO BANCO DE DADOS — Prisma ORM + PostgreSQL (Neon)
// ============================================================
// G-Pass: gerenciador de senhas corporativo.
// Cada model abaixo representa uma tabela no banco.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // definido em .env
}

// -------------------------------------------------------
// User — funcionários e administradores do sistema
// -------------------------------------------------------
// - role: "admin" ou "user" (funcionário comum)
// - status: "active" ou "inactive"
// - passphrase: hash bcrypt da frase secreta (login)
// - folderId: pasta automática criada para o funcionário
// - sortOrder: ordem de exibição no sidebar (drag-and-drop)
// -------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  avatar       String?
  role         String    @default("user")
  status       String    @default("active")
  passphrase   String?
  cargo        String?
  departamento String?
  telefone     String?
  mfaEnabled   Boolean   @default(false)
  lastLogin    DateTime?
  publicKey    String?
  folderId     String?
  sortOrder    Int       @default(0)
  tokenVersion Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  folder       Folder?        @relation(fields: [folderId], references: [id])
  passwords    Password[]     @relation("PasswordCreator")
  sharedWith   SharedAccess[]
  createdDocs  Document[]     @relation("DocumentCreator")
  attachedDocs Document[]     @relation("DocumentUser")
}

// -------------------------------------------------------
// Folder — pastas para organizar as senhas
// -------------------------------------------------------
// - parentId: auto-relacionamento para sub-pastas (árvore)
// - sortOrder: ordem de exibição (drag-and-drop)
// -------------------------------------------------------
model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  color     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    Folder?    @relation("FolderParent", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderParent")
  passwords Password[]
  users     User[]
  documents Document[] @relation("DocumentFolder")
}

// -------------------------------------------------------
// Password — a senha em si (criptografada em trânsito)
// -------------------------------------------------------
// Relacionamentos:
//   creator -> User (quem criou)
//   folder  -> Folder (pasta opcional)
//   tags    -> PasswordTag (N:N com Tag)
//   sharedWith -> SharedAccess (compartilhamento)
// -------------------------------------------------------
model Password {
  id        String   @id @default(cuid())
  name      String
  username  String
  password  String
  url       String?
  notes     String?
  favorite  Boolean  @default(false)
  folderId  String?
  createdBy String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator    User           @relation("PasswordCreator", fields: [createdBy], references: [id])
  folder     Folder?        @relation(fields: [folderId], references: [id])
  tags       PasswordTag[]
  sharedWith SharedAccess[]
}

// -------------------------------------------------------
// Tag — etiquetas coloridas para categorizar senhas
// -------------------------------------------------------
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?  @default("#0c11cf")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  passwords PasswordTag[]
  documents Document[]
}

// -------------------------------------------------------
// PasswordTag — tabela pivô N:N entre Password e Tag
// -------------------------------------------------------
model PasswordTag {
  passwordId String
  tagId      String

  password Password @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([passwordId, tagId])
}

// -------------------------------------------------------
// SharedAccess — controle de acesso: quem pode ver/editar
// -------------------------------------------------------
// - permission: "read" (só visualizar) ou "write" (editar)
// -------------------------------------------------------
model SharedAccess {
  id         String   @id @default(cuid())
  passwordId String
  userId     String
  permission String   @default("read")
  createdAt  DateTime @default(now())

  password Password @relation(fields: [passwordId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------
// Document — arquivos anexados a pastas, funcionários ou tags
// -------------------------------------------------------
// - mimeType: tipo do arquivo (pdf, txt, png, jpg, etc.)
// - storagePath: caminho relativo em public/uploads/
// - maxSize: 10MB
// - folderId: anexado a um cliente (pasta)
// - userId: anexado a um funcionário
// - tagId: anexado a uma tag
// -------------------------------------------------------
model Document {
  id          String   @id @default(cuid())
  name        String
  fileName    String
  mimeType    String
  size        Int
  storagePath String
  folderId    String?
  userId      String?
  tagId       String?
  createdBy   String
  createdAt   DateTime @default(now())

  folder  Folder? @relation("DocumentFolder", fields: [folderId], references: [id], onDelete: Cascade)
  user    User?   @relation("DocumentUser", fields: [userId], references: [id], onDelete: Cascade)
  tag     Tag?    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  creator User    @relation("DocumentCreator", fields: [createdBy], references: [id])
}
